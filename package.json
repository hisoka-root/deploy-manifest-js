{
  "name": "deploy-manifest",
  "version": "0.1.0",
  "description": "Parse and validate Deploy Manifest Specification files (Node, Bun, Deno)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["deploy", "manifest", "deployment", "devops", "dms"],
  "license": "MPL-2.0",
  "author": "hisoka <root@hisoka.lol>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hisoka-root/deploy-manifest-js.git"
  },
  "homepage": "https://github.com/hisoka-root/deploy-manifest-js",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
